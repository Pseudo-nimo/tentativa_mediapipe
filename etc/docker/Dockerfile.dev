FROM python:3.10-slim

WORKDIR /devel

RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        git \
        vim \
    && rm -rf /var/lib/apt/lists/*

# Pre-install heavy dependencies so iterative development is faster
RUN pip install --no-cache-dir \
        "mediapipe>=0.10.0" \
        "opencv-python>=4.5.0" \
        "is-wire>=1.1.2" \
        "is-msgs>=1.1.8" \
        python-dateutil \
        opencensus-ext-zipkin \
        grpcio-tools

CMD ["bash"]
